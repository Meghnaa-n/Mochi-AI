{
  "manifest_version": 3,
  "name": "AI Prompt Cat",
  "version": "1.0.0",
  "description": "Floating 3D cat that helps you write better prompts on ChatGPT and Claude",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["three.min.js", "GLTFLoader.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "models/cartoon_cat.glb",
        "three.min.js",
        "GLTFLoader.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ]
    }
  ]
}